@model ItemProcessor.Models.Item
@{ ViewData["Title"] = "Edit Item"; }

<h2>Edit Item</h2>
<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ItemId" type="hidden" />

            <div class="mb-3">
                <label asp-for="ItemName" class="form-label"></label>
                <input asp-for="ItemName" id="ItemName" class="form-control"/>
                <span asp-validation-for="ItemName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Weight" class="form-label">Weight (kg)</label>
                <input asp-for="Weight" id="Weight" class="form-control"
                       type="number" step="0.001" min="0.001"/>
                <span asp-validation-for="Weight" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" id="Description" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-warning">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>